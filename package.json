{
	"name": "react-flow-app-workspace",
	"private": true,
	"version": "0.0.0",
	"description": "Monorepo for react-flow-app — event-driven flow engine for React",
	"scripts": {
		"dev": "pnpm --filter web dev",
		"build": "pnpm --filter react-flow-app build && pnpm --filter web build",
		"build:pkg": "pnpm --filter react-flow-app build",
		"build:web": "pnpm --filter web build",
		"test": "pnpm --filter react-flow-app test",
		"test:coverage": "pnpm --filter react-flow-app test:coverage",
		"storybook": "pnpm --filter react-flow-app storybook",
		"storybook:build": "pnpm --filter react-flow-app storybook:build",
		"lint": "pnpm -r --filter react-flow-app lint"
	},
	"packageManager": "pnpm@10.29.3"
}
