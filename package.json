{
	"name": "react-flow-app",
	"version": "0.0.0",
	"description": "🚀 This is a React.js library to simplify navigations focused in events (user actions) for smooth integrations.",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist/"
	],
	"scripts": {
		"build": "node scripts/pre-build.js && tsc --project tsconfig.prod.json && node scripts/copy-files.js",
		"start": "npm run storybook",
		"storybook": "storybook dev -p 6006",
		"storybook:build": "storybook build",
		"storybook:serve": "npm run storybook:build && npx http-server ./storybook-static/",
		"lint": "biome check src/",
		"lint:fix": "biome check --write src/",
		"format": "biome format --write src/",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"prepare": "husky install",
		"git:pre-commit": "biome check --staged",
		"git:pre-push": "npm run build && npm run test:coverage",
		"docs:build": "typedoc",
		"docs:serve": "npm run docs:build && npx serve docs"
	},
	"peerDependencies": {
		"react": "^16.0.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@babel/core": "^7.26.10",
		"@babel/preset-env": "^7.26.9",
		"@babel/preset-react": "^7.26.3",
		"@babel/preset-typescript": "^7.27.0",
		"@biomejs/biome": "^2.4.8",
		"@commitlint/cli": "^13.2.0",
		"@commitlint/config-conventional": "^13.2.0",
		"@mdx-js/react": "^3.1.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^9.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^8.0.1",
		"@semantic-release/npm": "^8.0.0",
		"@semantic-release/release-notes-generator": "^10.0.2",
		"@storybook/addon-links": "^10.3.1",
		"@storybook/react-vite": "^10.3.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^26.0.14",
		"@types/node": "^14.0.23",
		"@types/react": "^19.1.0",
		"@typescript-eslint/eslint-plugin": "^2.7.0",
		"@typescript-eslint/parser": "^2.7.0",
		"@vitest/coverage-v8": "^4.1.0",
		"anysort": "^2.0.0",
		"babel-eslint": "10.1.0",
		"babel-jest": "^26.3.0",
		"babel-loader": "^8.1.0",
		"copy-dir": "^1.3.0",
		"cspell": "^4.1.0",
		"cspell-dict-en_us": "^1.3.7",
		"cspell-dict-en-gb": "^1.2.6",
		"cspell-dict-lorem-ipsum": "^1.1.2",
		"eslint": "^6.8.0",
		"eslint-config-prettier": "^6.11.0",
		"eslint-config-react-app": "^5.0.2",
		"eslint-loader": "3.0.0",
		"eslint-plugin-flowtype": "3.13.0",
		"eslint-plugin-import": "2.31.0",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-prettier": "^3.1.4",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "^1.6.1",
		"eslint-plugin-sonarjs": "^0.5.0",
		"husky": "^7.0.2",
		"jest": "^26.4.2",
		"jest-canvas-mock": "^2.5.2",
		"jest-environment-jsdom-fourteen": "^1.0.1",
		"jest-junit": "^11.1.0",
		"jest-sonar-reporter": "^2.0.0",
		"jest-watch-typeahead": "^0.6.0",
		"jsdom": "^29.0.0",
		"lint-staged": "^11.1.2",
		"prettier": "^1.19.1",
		"react": "^19.1.0",
		"react-app-polyfill": "^3.0.0",
		"react-dom": "^19.1.0",
		"rimraf": "^3.0.2",
		"serve": "^12.0.1",
		"storybook": "^10.3.1",
		"stylelint": "^13.6.1",
		"stylelint-config-recommended": "^3.0.0",
		"stylelint-config-styled-components": "^0.1.1",
		"stylelint-processor-styled-components": "^1.10.0",
		"ts-loader": "^8.0.3",
		"typedoc": "^0.28.2",
		"typescript": "^5.8.3",
		"vite": "^6.2.5",
		"vitest": "^4.1.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/fabio7maia/react-flow-app"
	},
	"author": {
		"email": "fabio7maia@gmail.com",
		"name": "Fábio Maia"
	},
	"keywords": [
		"react",
		"flow",
		"wizard",
		"step",
		"multisetp",
		"workflow",
		"state machine"
	]
}
